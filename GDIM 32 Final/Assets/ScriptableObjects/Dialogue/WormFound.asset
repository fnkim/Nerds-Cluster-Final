  _lines:
  - _portrait: {fileID: 21300000, guid: a0c4f9dc8bea74c4cb9e751139fb19f3, type: 3}
    _dialogueText: I found you a worm!
  - _portrait: {fileID: 21300000, guid: 01eacae4f7d9e3a458b36d97b4e3d04f, type: 3}
    _dialogueText: OMG YOU'RE SO SWEET THANK YOU!
  - _portrait: {fileID: 21300000, guid: 01eacae4f7d9e3a458b36d97b4e3d04f, type: 3}
