  m_Name: TravelerHint
  m_EditorClassIdentifier: 
  _lines:
  - _portrait: {fileID: 21300000, guid: 43c1216562d5e1c478203c4173861a26, type: 3}
    _dialogueText: The squirrel trader won't give me the flour I need to bake the
      tart...
  - _portrait: {fileID: 21300000, guid: 0af4b1638c305fd41aa4f92f0894584b, type: 3}
    _dialogueText: Maybe you should eat the squirrel and take the flour.
  - _portrait: {fileID: 21300000, guid: 43c1216562d5e1c478203c4173861a26, type: 3}
    _dialogueText: ...
  - _portrait: {fileID: 21300000, guid: 43c1216562d5e1c478203c4173861a26, type: 3}
    _dialogueText: ...is that your only solution to everything?
  - _portrait: {fileID: 21300000, guid: 0af4b1638c305fd41aa4f92f0894584b, type: 3}
    _dialogueText: Or maybe you can trade the flour for something rare?
  - _portrait: {fileID: 21300000, guid: 0af4b1638c305fd41aa4f92f0894584b, type: 3}
    _dialogueText: I don't care. Just get me the tart. I'm getting hungrier...
